<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="SafeTech 404 - Page Not Found">
  <title>404 - Page Not Found - SafeTech</title>
  <link rel="stylesheet" href="/css/premium.css">
  <style>
    .error-container {
      min-height: calc(100vh - 100px);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: var(--space-8);
      background: var(--gradient-dark);
      color: white;
      text-align: center;
    }

    .error-content {
      max-width: 600px;
    }

    .error-code {
      font-size: 8rem;
      font-weight: var(--font-extrabold);
      margin-bottom: var(--space-4);
      background: var(--gradient-glow);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .error-message {
      font-size: var(--text-2xl);
      font-weight: var(--font-bold);
      margin-bottom: var(--space-4);
    }

    .error-description {
      font-size: var(--text-lg);
      opacity: 0.9;
      margin-bottom: var(--space-8);
      line-height: 1.8;
    }

    .error-actions {
      display: flex;
      gap: var(--space-4);
      justify-content: center;
      flex-wrap: wrap;
    }

    .error-icon {
      font-size: 5rem;
      margin-bottom: var(--space-4);
      filter: drop-shadow(0 0 20px rgba(0, 153, 255, 0.3));
    }

    @media (max-width: 768px) {
      .error-code {
        font-size: 5rem;
      }

      .error-message {
        font-size: var(--text-xl);
      }

      .error-description {
        font-size: var(--text-base);
      }

      .error-actions {
        flex-direction: column;
      }

      .error-actions a {
        width: 100%;
      }
    }
  </style>
</head>
<body>
<nav class="navbar">
  <div class="navbar-container">
    <a href="/" class="logo">
      <span class="logo-icon">🛡️</span>
      <span>SafeTech</span>
    </a>
    <ul class="nav-menu">
      <li><a href="/">Home</a></li>
    </ul>
  </div>
</nav>
<div class="page-content">
  <div class="error-container">
    <div class="error-content">
      <div class="error-icon">😕</div>
      <div class="error-code">404</div>
      <div class="error-message">Page Not Found</div>
      <div class="error-description">
        The page you're looking for doesn't exist. It might have been moved or deleted.
      </div>
      <div class="error-actions">
        <a href="/" class="btn btn-primary btn-lg">🏠 Go Home</a>
        <a href="/dashboard" class="btn btn-secondary btn-lg">📊 Dashboard</a>
      </div>
    </div>
  </div>
</div>

<footer class="footer">
  <div class="footer-container">
    <div class="footer-section">
      <h4>About SafeTech</h4>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/">Features</a></li>
        <li><a href="/">Plans</a></li>
        <li><a href="#">Blog</a></li>
      </ul>
    </div>
    <div class="footer-section">
      <h4>Support</h4>
      <ul>
        <li><a href="#">Help Center</a></li>
        <li><a href="#">Contact Us</a></li>
        <li><a href="#">FAQ</a></li>
        <li><a href="#">Status</a></li>
      </ul>
    </div>
    <div class="footer-section">
      <h4>Legal</h4>
      <ul>
        <li><a href="#">Privacy Policy</a></li>
        <li><a href="#">Terms of Service</a></li>
        <li><a href="#">Security</a></li>
        <li><a href="#">Compliance</a></li>
      </ul>
    </div>
    <div class="footer-section">
      <h4>Connect</h4>
      <ul>
        <li><a href="#">Twitter</a></li>
        <li><a href="#">LinkedIn</a></li>
        <li><a href="#">Facebook</a></li>
        <li><a href="#">Instagram</a></li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <p>&copy; 2026 SafeTech. Enterprise-Grade Premium Device Insurance. All rights reserved.</p>
  </div>
</footer>

<script src="/js/main.js"></script>
</body>
</html>
