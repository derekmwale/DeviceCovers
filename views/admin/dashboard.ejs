<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="SafeTech Admin Panel - Manage Insurance Operations">
  <title>Premium Admin Panel - SafeTech</title>
  <link rel="stylesheet" href="/css/premium.css">
</head>
<body>
<nav class="navbar">
  <div class="navbar-container">
    <a href="/" class="logo">
      <span class="logo-icon">🛡️</span>
      <span>SafeTech</span>
    </a>
    <ul class="nav-menu">
      <li><a href="/admin">Admin Panel</a></li>
      <li><a href="/api/auth/logout" class="btn btn-primary">Logout</a></li>
    </ul>
  </div>
</nav>
<div class="page-content">
<div class="admin-dashboard">
  <div class="admin-header">
    <h1>Admin Panel</h1>
    <p>Welcome, Admin</p>
  </div>

  <div class="admin-nav">
    <button class="nav-btn active" data-page="overview">Overview</button>
    <button class="nav-btn" data-page="plans">Plans Review</button>
    <button class="nav-btn" data-page="claims">Claims Review</button>
    <button class="nav-btn" data-page="users">Users</button>
    <button class="nav-btn" data-page="reports">Reports</button>
  </div>

  <!-- Overview Page -->
  <div id="overview" class="admin-page active">
    <h2>Dashboard Overview</h2>
    <div class="admin-stats">
      <div class="stat">
        <h3>Total Users</h3>
        <p id="totalUsers">0</p>
      </div>
      <div class="stat">
        <h3>Active Plans</h3>
        <p id="totalPlans">0</p>
      </div>
      <div class="stat">
        <h3>Total Claims</h3>
        <p id="totalClaims">0</p>
      </div>
      <div class="stat">
        <h3>Pending Claims</h3>
        <p id="pendingClaims">0</p>
      </div>
      <div class="stat">
        <h3>Total Revenue</h3>
        <p id="totalRevenue">ZMW 0</p>
      </div>
    </div>
  </div>

  <!-- Plans Review Page -->
  <div id="plans" class="admin-page">
    <h2>Pending Plans for Approval</h2>
    <div id="pendingPlans" class="admin-table"></div>
  </div>

  <!-- Claims Review Page -->
  <div id="claims" class="admin-page">
    <h2>Claims Under Review</h2>
    <div id="claimsReview" class="admin-table"></div>
  </div>

  <!-- Users Page -->
  <div id="users" class="admin-page">
    <h2>All Users</h2>
    <div id="usersList" class="admin-table"></div>
  </div>

  <!-- Reports Page -->
  <div id="reports" class="admin-page">
    <h2>Reports</h2>
    <div id="reportContent"></div>
  </div>
</div>
</div>

<footer class="footer">
  <div class="footer-container">
    <div class="footer-section">
      <h4>Admin</h4>
      <ul>
        <li><a href="/admin">Dashboard</a></li>
        <li><a href="#">Users</a></li>
        <li><a href="#">Reports</a></li>
        <li><a href="#">Settings</a></li>
      </ul>
    </div>
    <div class="footer-section">
      <h4>Support</h4>
      <ul>
        <li><a href="#">Help Center</a></li>
        <li><a href="#">Documentation</a></li>
        <li><a href="#">FAQ</a></li>
        <li><a href="#">Issues</a></li>
      </ul>
    </div>
    <div class="footer-section">
      <h4>Legal</h4>
      <ul>
        <li><a href="#">Privacy Policy</a></li>
        <li><a href="#">Terms of Service</a></li>
        <li><a href="#">Security</a></li>
        <li><a href="#">Compliance</a></li>
      </ul>
    </div>
    <div class="footer-section">
      <h4>Account</h4>
      <ul>
        <li><a href="#">Profile</a></li>
        <li><a href="#">Settings</a></li>
        <li><a href="#">Security</a></li>
        <li><a href="/api/auth/logout">Logout</a></li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <p>&copy; 2026 SafeTech Admin Panel. Premium Device Insurance Management. All rights reserved.</p>
  </div>
</footer>

<script src="/js/admin.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
