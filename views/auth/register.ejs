<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register - SafeTech</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<nav class="navbar">
  <div class="navbar-container">
    <a href="/" class="logo">
      <div class="logo-icon">🛡️</div>
      <span>SafeTech</span>
    </a>
    <ul class="nav-menu">
      <li><a href="/">Home</a></li>
      <li><a href="/login">Login</a></li>
    </ul>
  </div>
</nav>

<div class="page-content">
  <div class="auth-page">
    <div class="auth-container">
      <!-- Left Side - Branding -->
      <div class="auth-branding">
        <div class="brand-content">
          <div class="brand-icon">🛡️</div>
          <h1>SafeTech</h1>
          <p class="brand-tagline">Enterprise-Grade Device Protection</p>
          
          <div class="brand-features">
            <div class="brand-feature">
              <span class="feature-icon">✓</span>
              <span>Quick Registration</span>
            </div>
            <div class="brand-feature">
              <span class="feature-icon">✓</span>
              <span>Start Protecting Today</span>
            </div>
            <div class="brand-feature">
              <span class="feature-icon">✓</span>
              <span>Affordable Plans</span>
            </div>
          </div>

          <div class="brand-stats">
            <div class="stat">
              <strong>10K+</strong>
              <small>Active Users</small>
            </div>
            <div class="stat">
              <strong>$2M+</strong>
              <small>Claims Processed</small>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Side - Form -->
      <div class="auth-form-container">
        <div class="auth-form-wrapper">
          <div class="form-header">
            <h2>Create Account</h2>
            <p>Join SafeTech and protect your devices today</p>
          </div>

          <form id="registerForm" class="modern-form">
            <div class="form-row">
              <div class="form-group">
                <label for="firstName">First Name</label>
                <input 
                  type="text" 
                  id="firstName" 
                  name="firstName" 
                  placeholder="John"
                  required 
                />
              </div>
              <div class="form-group">
                <label for="lastName">Last Name</label>
                <input 
                  type="text" 
                  id="lastName" 
                  name="lastName" 
                  placeholder="Doe"
                  required 
                />
              </div>
            </div>

            <div class="form-group">
              <label for="email">Email Address</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                placeholder="you@example.com"
                required 
              />
              <div class="form-icon">✉️</div>
            </div>

            <div class="form-group">
              <label for="password">Password</label>
              <input 
                type="password" 
                id="password" 
                name="password" 
                placeholder="At least 6 characters"
                required 
                minlength="6"
              />
              <div class="form-icon">🔐</div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="phone">Phone Number</label>
                <input 
                  type="tel" 
                  id="phone" 
                  name="phone" 
                  placeholder="+1 (555) 000-0000"
                  required 
                />
              </div>
              <div class="form-group">
                <label for="country">Country</label>
                <input 
                  type="text" 
                  id="country" 
                  name="country" 
                  placeholder="Zambia"
                  required 
                />
              </div>
            </div>

            <label class="checkbox-group">
              <input type="checkbox" name="terms" required />
              <span>I agree to the <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a></span>
            </label>

            <button type="submit" class="btn btn-primary btn-lg auth-btn">
              Create Account
            </button>
          </form>

          <div class="auth-divider">
            <span>Already have an account?</span>
          </div>

          <a href="/login" class="btn btn-secondary btn-lg auth-btn">
            Sign In
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<footer class="footer">
  <p>&copy; 2026 SafeTech. All rights reserved. Laptop Insurance Made Simple.</p>
</footer>

<script>
  document.getElementById('registerForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target);
    const data = Object.fromEntries(formData);

    try {
      const button = e.target.querySelector('button[type="submit"]');
      button.disabled = true;
      button.textContent = 'Creating Account...';

      const response = await fetch('/api/auth/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const result = await response.json();
      if (response.ok) {
        localStorage.setItem('token', result.token);
        window.location.href = '/dashboard';
      } else {
        alert(result.message || 'Registration failed');
        button.disabled = false;
        button.textContent = 'Create Account';
      }
    } catch (error) {
      alert('Registration failed: ' + error.message);
      const button = e.target.querySelector('button[type="submit"]');
      button.disabled = false;
      button.textContent = 'Create Account';
    }
  });
</script>

<style>
  /* Auth Page Layout */
  .auth-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--bg-secondary) 0%, var(--bg-tertiary) 100%);
    padding: var(--space-4);
  }

  .auth-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    width: 100%;
    max-width: 1200px;
    background: var(--bg-primary);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
  }

  /* Branding Section */
  .auth-branding {
    background: var(--gradient-primary);
    padding: var(--space-12);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .auth-branding::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 400px;
    height: 400px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
  }

  .brand-content {
    position: relative;
    z-index: 1;
    color: white;
    text-align: center;
  }

  .brand-icon {
    font-size: 4rem;
    margin-bottom: var(--space-4);
    display: block;
  }

  .brand-content h1 {
    font-size: 2rem;
    margin-bottom: var(--space-2);
    font-weight: 800;
  }

  .brand-tagline {
    font-size: 1.1rem;
    opacity: 0.95;
    margin-bottom: var(--space-8);
  }

  .brand-features {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .brand-feature {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: 1rem;
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    font-weight: bold;
  }

  .brand-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
    margin-top: var(--space-8);
    padding-top: var(--space-8);
    border-top: 1px solid rgba(255, 255, 255, 0.2);
  }

  .stat {
    text-align: center;
  }

  .stat strong {
    display: block;
    font-size: 1.5rem;
    margin-bottom: var(--space-1);
  }

  .stat small {
    font-size: 0.9rem;
    opacity: 0.9;
  }

  /* Form Section */
  .auth-form-container {
    padding: var(--space-12);
    display: flex;
    align-items: center;
    justify-content: center;
    max-height: 100vh;
    overflow-y: auto;
  }

  .auth-form-wrapper {
    width: 100%;
    max-width: 400px;
  }

  .form-header {
    margin-bottom: var(--space-8);
  }

  .form-header h2 {
    font-size: 2rem;
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .form-header p {
    color: var(--text-secondary);
    font-size: 1rem;
  }

  .modern-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .modern-form .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .modern-form .form-group {
    position: relative;
    margin-bottom: 0;
  }

  .modern-form .form-group label {
    display: block;
    margin-bottom: var(--space-2);
    font-weight: 600;
    color: var(--text-primary);
    font-size: 0.95rem;
  }

  .modern-form .form-group input {
    width: 100%;
    padding: var(--space-3) var(--space-4) var(--space-3) var(--space-4);
    padding-right: 40px;
    border: 2px solid var(--border);
    border-radius: 8px;
    font-size: 1rem;
    transition: all 0.3s ease;
    background: var(--bg-primary);
  }

  .modern-form .form-group input:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 4px rgba(0, 102, 255, 0.1);
  }

  .form-icon {
    position: absolute;
    right: var(--space-3);
    top: 50%;
    transform: translateY(-50%);
    margin-top: var(--space-5);
    font-size: 1.2rem;
    pointer-events: none;
  }

  .checkbox-group {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    cursor: pointer;
    user-select: none;
    margin: var(--space-4) 0;
  }

  .checkbox-group input[type="checkbox"] {
    width: 18px;
    height: 18px;
    cursor: pointer;
    accent-color: var(--primary);
    margin-top: 2px;
    flex-shrink: 0;
  }

  .checkbox-group span {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  .checkbox-group a {
    color: var(--primary);
    text-decoration: none;
  }

  .checkbox-group a:hover {
    text-decoration: underline;
  }

  .auth-btn {
    width: 100%;
    padding: var(--space-4) var(--space-6);
    font-size: 1.05rem;
    font-weight: 600;
    border: none;
    cursor: pointer;
  }

  .auth-divider {
    text-align: center;
    margin: var(--space-8) 0 var(--space-6) 0;
    color: var(--text-tertiary);
    font-size: 0.95rem;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .auth-container {
      grid-template-columns: 1fr;
    }

    .auth-branding {
      padding: var(--space-8);
    }

    .auth-form-container {
      padding: var(--space-8);
    }
  }

  @media (max-width: 768px) {
    .auth-page {
      padding: var(--space-4);
    }

    .auth-container {
      border-radius: 16px;
    }

    .auth-branding {
      display: none;
    }

    .auth-form-container {
      padding: var(--space-6);
      max-height: none;
    }

    .auth-form-wrapper {
      max-width: 100%;
    }

    .form-header h2 {
      font-size: 1.5rem;
    }

    .modern-form .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script src="/js/main.js"></script>
</body>
</html>
