        <li><a href="/dashboard">Dashboard</a></li>
        <li><a href="/api/auth/logout">Logout</a></li>
        <% } else { %>
        <li><a href="/login">Login</a></li>
        <li><a href="/register" class="btn btn-primary">Register</a></li>
        <% } %>
