<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="SafeTech Add Device - Register Your Laptop for Insurance">
  <title>Premium Add Device - SafeTech</title>
  <link rel="stylesheet" href="/css/premium.css">
</head>
<body>
<nav class="navbar">
  <div class="navbar-container">
    <a href="/" class="logo">
      <span class="logo-icon">🛡️</span>
      <span>SafeTech</span>
    </a>
    <ul class="nav-menu">
      <li><a href="/dashboard">Dashboard</a></li>
      <li><a href="/my-laptops">Devices</a></li>
      <li><a href="/payments">Payments</a></li>
      <li><a href="/claims">Claims</a></li>
      <li><a href="/api/auth/logout" class="btn btn-primary" style="margin-left: var(--space-4);">Logout</a></li>
    </ul>
  </div>
</nav>
<div class="page-content">
  <div class="dashboard">
    <div class="sidebar">
      <nav class="sidebar-nav">
        <a href="/dashboard" class="nav-item">📊 Overview</a>
        <a href="/my-laptops" class="nav-item">💻 My Laptops</a>
        <a href="/add-laptop" class="nav-item active">➕ Add Laptop</a>
        <a href="/plans" class="nav-item">🛡️ Insurance Plans</a>
        <a href="/payments" class="nav-item">💳 Payments</a>
        <a href="/claims" class="nav-item">📋 Claims</a>
      </nav>
    </div>

    <div class="dashboard-content">
  <div class="add-laptop-container">
    <div class="form-wrapper">
      <h1>Add New Laptop</h1>
      <p class="form-subtitle">Register your device to get insurance protection</p>

      <form id="addLaptopForm" enctype="multipart/form-data" class="laptop-form">
        <div class="form-section">
          <h3>Device Information</h3>
          
          <div class="form-row">
            <div class="form-group">
              <label for="brand">Brand *</label>
              <input type="text" id="brand" name="brand" placeholder="e.g., Apple, Dell, HP" required />
            </div>
            <div class="form-group">
              <label for="model">Model *</label>
              <input type="text" id="model" name="model" placeholder="e.g., MacBook Pro 14-inch" required />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="serialNumber">Serial Number *</label>
              <input type="text" id="serialNumber" name="serialNumber" placeholder="Device serial number" required />
            </div>
            <div class="form-group">
              <label for="condition">Condition *</label>
              <select id="condition" name="condition" required>
                <option value="">Select condition</option>
                <option value="excellent">Excellent (Like New)</option>
                <option value="good">Good (Minor Wear)</option>
                <option value="fair">Fair (Visible Wear)</option>
              </select>
            </div>
          </div>
        </div>

        <div class="form-section">
          <h3>Purchase Details</h3>
          
          <div class="form-row">
            <div class="form-group">
              <label for="purchaseValue">Purchase Value (ZMW) *</label>
              <input type="number" id="purchaseValue" name="purchaseValue" placeholder="Device cost in ZMW" required min="500" step="0.01" />
            </div>
            <div class="form-group">
              <label for="purchaseDate">Purchase Date *</label>
              <input type="date" id="purchaseDate" name="purchaseDate" required />
            </div>
          </div>

          <div class="form-group">
            <label for="receipt">Receipt Image (Optional)</label>
            <input type="file" id="receipt" name="receipt" accept="image/*" />
            <p class="form-hint">Upload your device receipt (JPG, PNG, max 5MB)</p>
          </div>
        </div>

        <div class="form-actions">
          <a href="/dashboard" class="btn btn-secondary" style="background: #ffffff; color: var(--secondary); border: 2px solid var(--secondary);">Cancel</a>
          <button type="submit" class="btn btn-primary" style="background: linear-gradient(135deg, #1e3a8a, #3b82f6); color: white; border: none;">Add Laptop</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  document.getElementById('addLaptopForm').addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(e.target);

    try {
      const response = await fetch('/api/laptop', {
        method: 'POST',
        body: formData,
        credentials: 'include', // Include session cookies
      });

      const result = await response.json();

      if (response.ok) {
        alert('Laptop added successfully!');
        window.location.href = '/dashboard';
      } else {
        alert(`Error: ${result.message || 'Failed to add laptop'}`);
      }
    } catch (error) {
      console.error('Error:', error);
      alert('Failed to add laptop: ' + error.message);
    }
  });

  // Set max date to today
  document.getElementById('purchaseDate').max = new Date().toISOString().split('T')[0];
</script>
    </div>
  </div>
</div>

