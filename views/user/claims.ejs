<div class="page-content">
  <div class="dashboard">
    <div class="sidebar">
      <nav class="sidebar-nav">
        <a href="/dashboard" class="nav-item">📊 Overview</a>
        <a href="/my-laptops" class="nav-item">💻 My Laptops</a>
        <a href="/add-laptop" class="nav-item">➕ Add Laptop</a>
        <a href="/plans" class="nav-item">🛡️ Insurance Plans</a>
        <a href="/payments" class="nav-item">💳 Payments</a>
        <a href="/claims" class="nav-item active">📋 Claims</a>
      </nav>
    </div>

    <div class="dashboard-content">
  <div class="claims-page-container" style="padding: var(--space-8); max-width: 1200px; margin: 0 auto;">
    <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-8); gap: var(--space-6);">
      <div class="header-content">
        <h1 style="font-size: var(--text-3xl); font-weight: var(--font-extrabold); color: var(--primary); margin-bottom: var(--space-2);">📋 Insurance Claims</h1>
        <p style="font-size: var(--text-base); color: var(--text-secondary);">Track and manage your insurance claims</p>
      </div>
      <div class="header-action">
        <button class="btn btn-primary btn-lg" onclick="showSubmitClaimForm()" style="background: linear-gradient(135deg, #1e3a8a, #3b82f6); color: white; border: none; padding: var(--space-4) var(--space-8); font-size: var(--text-base); font-weight: var(--font-bold); border-radius: var(--rounded-lg); cursor: pointer; transition: all var(--transition-base); white-space: nowrap;">+ Submit New Claim</button>
      </div>
    </div>

    <!-- Claims List -->
    <div class="claims-section" style="display: flex; flex-direction: column; gap: var(--space-6); margin-bottom: var(--space-12);">
      <div id="claimsList" class="claims-list-container" style="display: flex; flex-direction: column; gap: var(--space-6);"></div>
    </div>
  </div>
</div>


<script>
  async function apiCall(url, options = {}) {
    const headers = {
      'Content-Type': 'application/json',
      ...options.headers,
    };

    const response = await fetch(url, {
      ...options,
      headers,
      credentials: 'include', // Include session cookies
    });

    if (!response.ok) {
      if (response.status === 401) {
        window.location.href = '/login';
      }
      const error = await response.json();
      throw new Error(error.message || 'API Error');
    }

    return response.json();
  }

  // Load Claims
  async function loadClaims() {
    try {
      const claims = await apiCall('/api/claim');
      
      const html = claims.length > 0
        ? claims.map(claim => `
          <div class="claim-card-detailed">
            <div class="claim-header">
              <h3>Claim #${claim.claimNumber}</h3>
              <span class="badge badge-${claim.status}">${claim.status}</span>
            </div>
            <div class="claim-details">
              <div class="detail-row">
                <span class="label">Device:</span>
                <span class="value">${claim.laptop?.brand || 'N/A'} ${claim.laptop?.model || ''}</span>
              </div>
              <div class="detail-row">
                <span class="label">Claim Type:</span>
                <span class="value">${claim.claimType?.toUpperCase()}</span>
              </div>
              <div class="detail-row">
                <span class="label">Amount:</span>
                <span class="value">ZMW ${claim.estimatedCost?.toFixed(2) || '0.00'}</span>
              </div>
              <div class="detail-row">
                <span class="label">Submitted:</span>
                <span class="value">${new Date(claim.createdAt).toLocaleDateString()}</span>
              </div>
              <div class="detail-row">
                <span class="label">Description:</span>
                <span class="value">${claim.description || 'No description'}</span>
              </div>
            </div>
            <div class="claim-actions">
              <button class="btn btn-secondary" onclick="trackClaim('${claim._id}')">Track Progress</button>
              ${claim.status === 'pending' ? `<button class="btn btn-danger" onclick="withdrawClaim('${claim._id}')">Withdraw</button>` : ''}
            </div>
          </div>
        `).join('')
        : '<div class="empty-state"><p>No claims yet. If you need to submit a claim, click the button above.</p></div>';
      
      document.getElementById('claimsList').innerHTML = html;
    } catch (error) {
      console.error('Error loading claims:', error);
      document.getElementById('claimsList').innerHTML = `<div class="error-message">Error loading claims: ${error.message}</div>`;
    }
  }

  // Show Submit Claim Form
  async function showSubmitClaimForm() {
    try {
      const response = await fetch('/api/laptop');
      const laptops = await response.json();
      
      if (!laptops || laptops.length === 0) {
        showNotification('Please add a laptop and activate an insurance plan first.', 'error');
        return;
      }

      const laptopOptions = laptops
        .filter(l => l.status === 'active' && l.currentPlan)
        .map(l => `<option value="${l._id}">${l.brand} ${l.model}</option>`)
        .join('');

      if (!laptopOptions) {
        showNotification('Please activate an insurance plan for a laptop first.', 'error');
        return;
      }

      const modal = `
        <div class="mobile-money-overlay" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.7); backdrop-filter: blur(5px); z-index: 10000; display: flex; align-items: center; justify-content: center; padding: var(--space-4);">
          <div class="mobile-money-container" style="background: #ffffff; border-radius: var(--rounded-xl); box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3); max-width: 500px; width: 100%; max-height: 90vh; overflow-y: auto;">
            <!-- Header -->
            <div class="mm-header" style="display: flex; align-items: center; justify-content: space-between; padding: var(--space-6); border-bottom: 1px solid rgba(59, 130, 246, 0.1); background: linear-gradient(135deg, #1e3a8a, #3b82f6); color: white; border-radius: var(--rounded-xl) var(--rounded-xl) 0 0;">
              <button class="mm-back-btn" onclick="closeModal()" style="background: rgba(255, 255, 255, 0.2); border: none; color: white; padding: var(--space-2) var(--space-4); border-radius: var(--rounded-md); cursor: pointer; font-weight: var(--font-semibold); transition: all var(--transition-base);">← Back</button>
              <h1 style="margin: 0; font-size: var(--text-xl); font-weight: var(--font-bold);">📋 Submit Claim</h1>
              <div></div>
            </div>
            
            <!-- Form -->
            <div style="padding: var(--space-6);">
              <form id="submitClaimForm" style="display: flex; flex-direction: column; gap: var(--space-6);">
                <div class="form-group" style="margin-bottom: 0;">
                  <label for="laptopId" style="display: block; font-weight: var(--font-semibold); margin-bottom: var(--space-2); color: var(--text-primary); font-size: var(--text-sm);">Select Device *</label>
                  <select id="laptopId" name="laptopId" required style="width: 100%; padding: var(--space-3) var(--space-4); border: 2px solid rgba(59, 130, 246, 0.15); border-radius: var(--rounded-md); font-family: inherit; font-size: var(--text-base); font-weight: 500; transition: all var(--transition-base); background: #ffffff; color: var(--text-primary);">
                    <option value="">Choose a device...</option>
                    ${laptopOptions}
                  </select>
                </div>
                <div class="form-group" style="margin-bottom: 0;">
                  <label for="incidentDate" style="display: block; font-weight: var(--font-semibold); margin-bottom: var(--space-2); color: var(--text-primary); font-size: var(--text-sm);">Incident Date *</label>
                  <input type="date" id="incidentDate" name="incidentDate" required style="width: 100%; padding: var(--space-3) var(--space-4); border: 2px solid rgba(59, 130, 246, 0.15); border-radius: var(--rounded-md); font-family: inherit; font-size: var(--text-base); font-weight: 500; transition: all var(--transition-base); background: #ffffff; color: var(--text-primary);" />
                </div>
                <div class="form-group" style="margin-bottom: 0;">
                  <label for="claimType" style="display: block; font-weight: var(--font-semibold); margin-bottom: var(--space-2); color: var(--text-primary); font-size: var(--text-sm);">Claim Type *</label>
                  <select id="claimType" name="claimType" required style="width: 100%; padding: var(--space-3) var(--space-4); border: 2px solid rgba(59, 130, 246, 0.15); border-radius: var(--rounded-md); font-family: inherit; font-size: var(--text-base); font-weight: 500; transition: all var(--transition-base); background: #ffffff; color: var(--text-primary);">
                    <option value="">Select claim type...</option>
                    <option value="damage">🔨 Damage</option>
                    <option value="theft">🚨 Theft</option>
                    <option value="loss">❌ Loss</option>
                    <option value="water">💧 Water Damage</option>
                    <option value="other">📝 Other</option>
                  </select>
                </div>
                <div class="form-group" style="margin-bottom: 0;">
                  <label for="description" style="display: block; font-weight: var(--font-semibold); margin-bottom: var(--space-2); color: var(--text-primary); font-size: var(--text-sm);">Description *</label>
                  <textarea id="description" name="description" rows="3" placeholder="Describe what happened..." required style="width: 100%; padding: var(--space-3) var(--space-4); border: 2px solid rgba(59, 130, 246, 0.15); border-radius: var(--rounded-md); font-family: inherit; font-size: var(--text-base); font-weight: 500; transition: all var(--transition-base); background: #ffffff; color: var(--text-primary); resize: vertical;"></textarea>
                </div>
                <div class="form-group" style="margin-bottom: 0;">
                  <label for="location" style="display: block; font-weight: var(--font-semibold); margin-bottom: var(--space-2); color: var(--text-primary); font-size: var(--text-sm);">Location of Incident *</label>
                  <input type="text" id="location" name="location" placeholder="Where did it happen?" required style="width: 100%; padding: var(--space-3) var(--space-4); border: 2px solid rgba(59, 130, 246, 0.15); border-radius: var(--rounded-md); font-family: inherit; font-size: var(--text-base); font-weight: 500; transition: all var(--transition-base); background: #ffffff; color: var(--text-primary);" />
                </div>
                <div class="form-group" style="margin-bottom: 0;">
                  <label for="estimatedCost" style="display: block; font-weight: var(--font-semibold); margin-bottom: var(--space-2); color: var(--text-primary); font-size: var(--text-sm);">Estimated Cost (ZMW) *</label>
                  <input type="number" id="estimatedCost" name="estimatedCost" min="0" step="0.01" required placeholder="0.00" style="width: 100%; padding: var(--space-3) var(--space-4); border: 2px solid rgba(59, 130, 246, 0.15); border-radius: var(--rounded-md); font-family: inherit; font-size: var(--text-base); font-weight: 500; transition: all var(--transition-base); background: #ffffff; color: var(--text-primary);" />
                </div>
                <button type="submit" class="btn btn-primary" style="width: 100%; padding: var(--space-3) var(--space-4); background: linear-gradient(135deg, #1e3a8a, #3b82f6); color: white; border: none; border-radius: var(--rounded-lg); font-weight: var(--font-bold); font-size: var(--text-base); cursor: pointer; transition: all var(--transition-base); margin-top: var(--space-4);">✓ Submit Claim</button>
              </form>
            </div>
          </div>
        </div>
      `;

      document.body.insertAdjacentHTML('beforeend', modal);

      // Add event listener to the form
      const formEl = document.getElementById('submitClaimForm');
      if (formEl) {
        formEl.addEventListener('submit', async (e) => {
          e.preventDefault();

          const laptopId = document.getElementById('laptopId').value;
          const incidentDate = document.getElementById('incidentDate').value;
          const claimType = document.getElementById('claimType').value;
          const description = document.getElementById('description').value;
          const location = document.getElementById('location').value;
          const estimatedCost = document.getElementById('estimatedCost').value;

          if (!laptopId || !incidentDate || !claimType || !description || !location || !estimatedCost) {
            showNotification('Please fill in all required fields', 'error');
            return;
          }

          const data = {
            laptopId: laptopId,
            incidentDate: incidentDate,
            claimType: claimType,
            description: description,
            location: location,
            reportedToPolice: false,
            estimatedCost: parseFloat(estimatedCost),
          };

          try {
            const response = await fetch('/api/claim', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(data),
            });

            const result = await response.json();
            if (response.ok) {
              showNotification('✓ Claim submitted successfully! Claim #' + (result.claimNumber || ''), 'success');
              setTimeout(() => {
                closeModal();
                loadClaims();
              }, 1500);
            } else {
              showNotification(result.message || 'Error submitting claim', 'error');
            }
          } catch (error) {
            console.error('Error:', error);
            showNotification('Error submitting claim: ' + error.message, 'error');
          }
        });
      }
    } catch (error) {
      console.error('Error loading form:', error);
      showNotification('Error loading form: ' + error.message, 'error');
    }
  }

  // Track Claim
  async function trackClaim(claimId) {
    try {
      const claim = await apiCall(`/api/claim/${claimId}`);
      
      const timeline = `
        <div class="timeline">
          ${claim.timeline ? claim.timeline.map(event => `
            <div class="timeline-item">
              <div class="timeline-date">${new Date(event.date).toLocaleDateString()}</div>
              <div class="timeline-content">
                <h4>${event.status}</h4>
                <p>${event.note}</p>
              </div>
            </div>
          `).join('') : '<p>No updates yet. We will keep you informed.</p>'}
        </div>
      `;

      const modal = `
        <div class="modal-overlay" onclick="closeModal(event)">
          <div class="modal-content" onclick="event.stopPropagation()">
            <button class="modal-close" onclick="closeModal()">&times;</button>
            <h2>Claim #${claim.claimNumber} - Progress</h2>
            <div class="claim-tracking">
              <p><strong>Status:</strong> ${claim.status}</p>
              <p><strong>Current:</strong> ${claim.currentStatus}</p>
              ${timeline}
            </div>
          </div>
        </div>
      `;

      document.body.insertAdjacentHTML('beforeend', modal);
    } catch (error) {
      alert('Error tracking claim: ' + error.message);
    }
  }

  async function withdrawClaim(claimId) {
    if (confirm('Are you sure you want to withdraw this claim?')) {
      try {
        await apiCall(`/api/claim/${claimId}`, {
          method: 'PUT',
          body: JSON.stringify({ status: 'withdrawn' })
        });
        alert('Claim withdrawn successfully.');
        loadClaims();
      } catch (error) {
        alert('Error withdrawing claim: ' + error.message);
      }
    }
  }

  function closeModal(event) {
    if (event && event.target !== event.currentTarget) return;
    const modal = document.querySelector('.modal-overlay');
    if (modal) modal.remove();
  }

  // Load on page load
  window.addEventListener('load', () => {
    loadClaims();
  });
</script>
