<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="DeviceCovers User Dashboard - Manage Insurance & Devices">
  <title>Premium Dashboard - DeviceCovers</title>
  <link rel="stylesheet" href="/css/premium.css">
</head>
<body>
<nav class="navbar">
  <div class="navbar-container">
    <a href="/" class="logo">
      <span class="logo-icon">🛡️</span>
      <span>DeviceCovers</span>
    </a>
    <ul class="nav-menu">
      <li><a href="/dashboard" class="active">Dashboard</a></li>
      <li><a href="/my-laptops">Devices</a></li>
      <li><a href="/payments">Payments</a></li>
      <li><a href="/claims">Claims</a></li>
      <li><a href="/api/auth/logout" class="btn btn-primary" style="margin-left: var(--space-4);">Logout</a></li>
    </ul>
  </div>
</nav>
<div class="page-content">
<div class="dashboard-container">
  <div class="dashboard-header">
    <h1>👋 Welcome Back!</h1>
    <p>Your insurance dashboard - manage policies, payments, and claims in one place</p>
  </div>

  <!-- Stats Grid -->
  <div class="dashboard-grid">
    <div class="card">
      <div class="card-header">
        <div class="card-title">🛡️ Active Policies</div>
        <span class="card-badge" id="activePoliciesBadge">0 Active</span>
      </div>
      <div style="font-size: 2.5rem; font-weight: var(--font-extrabold); color: var(--primary); margin: var(--space-4) 0;">
        <span id="activePolicies">0</span>
      </div>
      <p style="color: var(--text-secondary); font-size: var(--text-sm);">Devices covered this month</p>
    </div>

    <div class="card">
      <div class="card-header">
        <div class="card-title">💰 Total Coverage</div>
        <span class="card-badge" style="background: var(--success-light); color: var(--success);">Premium</span>
      </div>
      <div style="font-size: 2.5rem; font-weight: var(--font-extrabold); background: var(--gradient-accent); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin: var(--space-4) 0;">
        <span id="totalCoverage">ZMW 0</span>
      </div>
      <p style="color: var(--text-secondary); font-size: var(--text-sm);">Total protection value</p>
    </div>

    <div class="card">
      <div class="card-header">
        <div class="card-title">💳 Monthly Payment</div>
        <span class="card-badge" id="paymentStatusBadge">Pending</span>
      </div>
      <div style="font-size: 2.5rem; font-weight: var(--font-extrabold); color: var(--secondary); margin: var(--space-4) 0;">
        <span id="monthlyPayment">ZMW 0</span>
      </div>
      <p style="color: var(--text-secondary); font-size: var(--text-sm);">Next billing cycle</p>
    </div>

    <div class="card">
      <div class="card-header">
        <div class="card-title">📋 Claims Status</div>
        <span class="card-badge" id="claimsStatusBadge">0 Pending</span>
      </div>
      <div style="font-size: 2.5rem; font-weight: var(--font-extrabold); color: var(--warning); margin: var(--space-4) 0;">
        <span id="claimsStatus">0</span>
      </div>
      <p style="color: var(--text-secondary); font-size: var(--text-sm);">Under review or approved</p>
    </div>
  </div>

  <!-- Quick Actions -->
  <div style="background: #ffffff; padding: var(--space-8); border-radius: var(--rounded-xl); border: 1px solid rgba(59, 130, 246, 0.1); margin-bottom: var(--space-12); box-shadow: var(--shadow-md);">
    <h2 style="font-size: var(--text-xl); font-weight: var(--font-bold); margin-bottom: var(--space-4); color: var(--primary);">Quick Actions</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: var(--space-4);">
      <a href="/add-laptop" class="btn btn-primary" style="justify-content: center; background: #ffffff; color: var(--primary); border: 2px solid var(--primary);">➕ Add Device</a>
      <a href="/select-plan" class="btn btn-secondary" style="justify-content: center; background: #ffffff; color: var(--secondary); border: 2px solid var(--secondary);">🛡️ Buy Insurance</a>
      <a href="/payments" class="btn btn-outline" style="justify-content: center; background: #ffffff; color: var(--primary); border: 2px solid var(--primary);">💳 Make Payment</a>
      <a href="/claims" class="btn btn-outline" style="justify-content: center; background: #ffffff; color: var(--primary); border: 2px solid var(--primary);">📝 File Claim</a>
    </div>
  </div>

  <!-- Recent Activity -->
  <div style="background: #ffffff; padding: var(--space-8); border-radius: var(--rounded-xl); border: 1px solid rgba(59, 130, 246, 0.1); box-shadow: var(--shadow-md);">
    <h2 style="font-size: var(--text-xl); font-weight: var(--font-bold); margin-bottom: var(--space-6); color: var(--primary);">Recent Activity</h2>
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>Date</th>
            <th>Activity</th>
            <th>Status</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody id="recentActivityBody">
          <tr>
            <td>Today</td>
            <td>Insurance Policy Active</td>
            <td><span class="card-badge" style="background: var(--success-light); color: var(--success);">Active</span></td>
            <td><a href="/payments" style="color: var(--secondary); text-decoration: none; font-weight: var(--font-semibold);">View →</a></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

</div>

<footer class="footer">
  <div class="footer-container">
    <div class="footer-section">
      <h4>Dashboard</h4>
      <ul>
        <li><a href="/my-laptops">My Devices</a></li>
        <li><a href="/payments">Payments</a></li>
        <li><a href="/claims">Claims</a></li>
        <li><a href="/plans">Plans</a></li>
      </ul>
    </div>
    <div class="footer-section">
      <h4>Support</h4>
      <ul>
        <li><a href="#">Help Center</a></li>
        <li><a href="#">Contact Support</a></li>
        <li><a href="#">FAQ</a></li>
        <li><a href="#">Documentation</a></li>
      </ul>
    </div>
    <div class="footer-section">
      <h4>Legal</h4>
      <ul>
        <li><a href="#">Privacy Policy</a></li>
        <li><a href="#">Terms of Service</a></li>
        <li><a href="#">Security</a></li>
        <li><a href="#">Compliance</a></li>
      </ul>
    </div>
    <div class="footer-section">
      <h4>Account</h4>
      <ul>
        <li><a href="#">Profile Settings</a></li>
        <li><a href="#">Security</a></li>
        <li><a href="#">Preferences</a></li>
        <li><a href="/api/auth/logout">Logout</a></li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <p>&copy; 2026 DeviceCovers. Premium Device Insurance. All rights reserved.</p>
  </div>
</footer>

<script src="/js/dashboard.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
