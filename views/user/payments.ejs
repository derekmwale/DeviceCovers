        <a href="/claims" class="nav-item">📋 Claims</a>
      </nav>
    </div>

    <div class="dashboard-content">
  <div class="payments-page-container">
    <div class="page-header">
      <div class="header-content">
        <h1>💳 Payment Management</h1>
        <p>View and manage your insurance premium payments</p>
      </div>
      <div class="header-action">
        <div class="quick-stat">
          <span class="label">Total Paid</span>
          <span class="value" id="totalPaidQuick">ZMW 0.00</span>
        </div>
      </div>
    </div>

    <!-- Payment Stats -->
    <div class="payment-stats">
      <div class="stat-card">
        <div class="stat-icon">💰</div>
        <h3>Total Paid</h3>
        <p class="stat-value" id="totalPaid">ZMW 0.00</p>
      </div>
      <div class="stat-card">
        <div class="stat-icon">⏳</div>
        <h3>Pending Payments</h3>
        <p class="stat-value" id="pendingCount">0</p>
      </div>
      <div class="stat-card">
        <div class="stat-icon">📊</div>
        <h3>Monthly Average</h3>
        <p class="stat-value" id="monthlyAvg">ZMW 0.00</p>
      </div>
    </div>

    <!-- Pending Payments Alert -->
    <div id="pendingPaymentsAlert" class="alert alert-warning" style="display: none;">
      <h3>⚠️ Action Required</h3>
      <p>You have pending payments. Please complete them to maintain your coverage.</p>
    </div>

    <!-- Payments Table -->
    <div class="payments-table-section">
      <h2>Payment History</h2>
      <div class="table-responsive">
        <table class="payments-table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Amount</th>
              <th>Plan</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="paymentsTableBody">
            <tr><td colspan="5" class="loading">Loading payments...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Pending Payments Alert -->
    <div id="pendingPaymentsAlert" class="alert alert-warning" style="display: none;">
      <h3>⚠️ Action Required</h3>
      <p>You have pending payments. Please complete them to maintain your coverage.</p>
    </div>
  </div>
</div>

<script>
  async function apiCall(url, options = {}) {
    const headers = {
      'Content-Type': 'application/json',
      ...options.headers,
    };

    const response = await fetch(url, {
      ...options,
      headers,
      credentials: 'include', // Include session cookies
    });

    if (!response.ok) {
      if (response.status === 401) {
        window.location.href = '/login';
      }
      const error = await response.json();
      throw new Error(error.message || 'API Error');
    }

    return response.json();
  }

  // Load Payments
  async function loadPayments() {
    try {
      const payments = await apiCall('/api/payment');
      
      let totalPaid = 0;
      let pendingCount = 0;
      const pendingPayments = [];

      const html = payments.length > 0
        ? payments.map(payment => {
          if (payment.status === 'completed' || payment.status === 'paid') {
            totalPaid += payment.amount || 0;
          } else if (payment.status === 'pending') {
            pendingCount++;
            pendingPayments.push(payment);
          }

          return `
            <tr>
              <td>${new Date(payment.createdAt).toLocaleDateString()}</td>
              <td class="amount">ZMW ${(payment.amount || 0).toFixed(2)}</td>
              <td>${payment.plan?.planType?.toUpperCase() || 'N/A'}</td>
              <td>
                <span class="badge badge-${payment.status}">
                  ${payment.status === 'pending' ? '⏳ Pending' : payment.status === 'paid' ? '✓ Paid' : '✓ Completed'}
                </span>
              </td>
              <td>
                ${payment.status === 'pending' 
                  ? `<button class="btn btn-sm btn-primary" onclick="payNow('${payment._id}')">Pay Now</button>`
                  : `<button class="btn btn-sm btn-secondary" onclick="viewReceipt('${payment._id}')">Receipt</button>`
                }
              </td>
            </tr>
          `;
        }).join('')
        : '<tr><td colspan="5" class="empty">No payments yet.</td></tr>';

      document.getElementById('paymentsTableBody').innerHTML = html;

      // Update stats
      document.getElementById('totalPaid').textContent = 'ZMW ' + totalPaid.toFixed(2);
      document.getElementById('pendingCount').textContent = pendingCount;
      
      if (payments.length > 0) {
        const avgPaid = totalPaid / payments.length;
        document.getElementById('monthlyAvg').textContent = 'ZMW ' + avgPaid.toFixed(2);
      }

      // Show pending alert if needed
      if (pendingCount > 0) {
        document.getElementById('pendingPaymentsAlert').style.display = 'block';
      }
    } catch (error) {
      console.error('Error loading payments:', error);
      document.getElementById('paymentsTableBody').innerHTML = `<tr><td colspan="5" class="error">Error loading payments: ${error.message}</td></tr>`;
    }
  }

  // Pay Now - Show Mobile Money Payment Page
  function payNow(paymentId) {
    // Store the payment ID in sessionStorage for the mobile money page
    sessionStorage.setItem('currentPaymentId', paymentId);
    
    // Load the mobile money payment page
    loadMobileMoneyPaymentPage(paymentId);
  }
  
  // Load Mobile Money Payment Page
  async function loadMobileMoneyPaymentPage(paymentId) {
    try {
      const payment = await apiCall(`/api/payment/${paymentId}`);
      
      const pageHTML = `
        <div id="mobile-money-overlay" class="mobile-money-overlay">
          <div class="mobile-money-container">
            <!-- Header -->
            <div class="mm-header">
              <button class="mm-back-btn" onclick="backToPayments()">← Back</button>
              <h1>💳 Payment Method</h1>
              <div></div>
            </div>
            
            <!-- Payment Summary -->
            <div class="mm-payment-summary">
              <div class="mm-summary-card">
                <h2>Payment Details</h2>
                <div class="mm-detail-row">
                  <span class="label">Amount:</span>
                  <span class="value">ZMW ${payment.amount.toFixed(2)}</span>
                </div>
                <div class="mm-detail-row">
                  <span class="label">Plan:</span>
                  <span class="value">${payment.plan?.planType?.toUpperCase() || 'N/A'}</span>
                </div>
                <div class="mm-detail-row">
                  <span class="label">Due Date:</span>
                  <span class="value">${new Date(payment.dueDate).toLocaleDateString()}</span>
                </div>
              </div>
            </div>
            
            <!-- Payment Methods -->
            <div class="mm-payment-methods">
              <h2>Payment Method</h2>
              
              <!-- Mobile Money (Primary) -->
              <div class="mm-method-card mm-method-primary" onclick="showMobileMoneyPhoneForm('${paymentId}')">
                <div class="mm-method-header">
                  <div class="mm-method-icon">📱</div>
                  <div class="mm-method-title">
                    <h3>Mobile Money</h3>
                    <p>MTN, Airtel</p>
                  </div>
                  <div class="mm-method-arrow">→</div>
                </div>
                <div class="mm-method-description">
                  Quick, secure payment via mobile money
                </div>
              </div>
            </div>
            
            <!-- Footer -->
            <div class="mm-footer">
              <p>Your payment is secure and encrypted</p>
            </div>
          </div>
        </div>
      `;
      
      // Remove any existing overlay first
      const existingOverlay = document.getElementById('mobile-money-overlay');
      if (existingOverlay) {
        existingOverlay.remove();
      }
      
      // Insert the overlay at the end of body
      document.body.insertAdjacentHTML('beforeend', pageHTML);
    } catch (error) {
      alert('Error loading payment page: ' + error.message);
    }
  }
  
  // Back to Payments
  function backToPayments() {
    const overlay = document.getElementById('mobile-money-overlay');
    if (overlay) {
      overlay.remove();
    }
    sessionStorage.removeItem('currentPaymentId');
  }

  // Show Mobile Money Phone Number Form
  function showMobileMoneyPhoneForm(paymentId) {
    // Get the payment methods section
    const paymentMethodsSection = document.querySelector('.mm-payment-methods');
    
    if (paymentMethodsSection) {
      // Replace content with phone form
      paymentMethodsSection.innerHTML = `
        <div class="mm-phone-form-container">
          <button class="mm-back-to-methods-btn" onclick="loadMobileMoneyPaymentPage('${paymentId}')">← Back to Methods</button>
          <h2>📱 Enter Mobile Money Details</h2>
          <form id="phoneForm" onsubmit="submitPhoneNumber(event, '${paymentId}')">
            <div class="form-group">
              <label for="phoneNumber">Phone Number</label>
              <div class="phone-input-group">
                <span class="phone-prefix">+260</span>
                <input 
                  type="tel" 
                  id="phoneNumber" 
                  placeholder="97XXXXXXX" 
                  maxlength="9" 
                  pattern="[0-9]{9}"
                  required 
                  title="Enter a valid Zambian phone number (9 digits)"
                  autofocus
                />
              </div>
              <small>Format: Enter without +260 (e.g., 971234567)</small>
            </div>
            <div class="form-group">
              <label for="provider">Mobile Provider</label>
              <select id="provider" required>
                <option value="">Select your provider</option>
                <option value="mtn">📱 MTN</option>
                <option value="airtel">📱 Airtel</option>
              </select>
            </div>
            <button type="submit" class="btn btn-primary btn-full">Continue to Payment →</button>
          </form>
        </div>
      `;
    }
  }

  // Submit Phone Number and Initiate Payment
  async function submitPhoneNumber(event, paymentId) {
    event.preventDefault();
    
    const phoneNumber = document.getElementById('phoneNumber').value;
    const provider = document.getElementById('provider').value;
    
    if (!phoneNumber || phoneNumber.length !== 9) {
      alert('Please enter a valid 9-digit phone number');
      return;
    }

    if (!provider) {
      alert('Please select a mobile provider');
      return;
    }

    // Format phone number with country code
    const fullPhoneNumber = '+260' + phoneNumber;
    
    // Initiate Lenco payment with phone number (no need to close modal)
    initiateLencoPayment(paymentId, fullPhoneNumber, provider);
  }

  // Initiate Lenco Mobile Money Payment
  async function initiateLencoPayment(paymentId, phoneNumber = null, provider = null) {
    try {
      // Get the payment methods section
      const paymentMethodsSection = document.querySelector('.mm-payment-methods');
      
      // Show loading indicator in the section
      if (paymentMethodsSection) {
        paymentMethodsSection.innerHTML = `
          <div class="mm-loading-container">
            <div class="loading-spinner">
              <div class="spinner"></div>
            </div>
            <p>Initializing mobile money payment...</p>
          </div>
        `;
      }

      console.log('💳 Initiating Lenco payment for payment:', paymentId);

      const response = await apiCall('/api/payment/lenco/initiate', {
        method: 'POST',
        body: JSON.stringify({ 
          paymentId,
          phoneNumber,
          provider
        })
      });

      if (!response.data || !response.data.authorizationUrl) {
        throw new Error('Failed to get payment authorization URL');
      }

      console.log('✅ Lenco payment initiated:', {
        transactionId: response.data.transactionId,
        reference: response.data.reference,
        authorizationUrl: response.data.authorizationUrl,
      });

      // Show success message in the payment methods section (not as modal)
      if (paymentMethodsSection) {
        paymentMethodsSection.innerHTML = `
          <div class="mm-success-container">
            <div class="success-icon-large">✓</div>
            <h2>Payment Initiated</h2>
            <p>You will be redirected to complete your mobile money payment</p>
            <div class="payment-details-inline">
              <p><strong>Reference:</strong> ${response.data.reference}</p>
              <p><strong>Transaction ID:</strong> ${response.data.transactionId}</p>
            </div>
            <button class="btn btn-primary btn-block" onclick="redirectToLenco('${response.data.authorizationUrl}', '${response.data.transactionId}')">
              Continue to Payment Provider →
            </button>
            <p style="margin-top: 15px; font-size: 0.9em; color: #666; text-align: center;">
              After completing payment, you'll be redirected back. Click below to reload payments if needed.
            </p>
            <button class="btn btn-secondary btn-block" onclick="location.reload()">
              Reload Payments Page
            </button>
            <button class="btn btn-outline btn-block" onclick="loadMobileMoneyPaymentPage('${paymentId}')">
              ← Back to Payment Methods
            </button>
          </div>
        `;
      }
    } catch (error) {
      console.error('❌ Lenco payment error:', error);
      
      // Show error message in the section
      const paymentMethodsSection = document.querySelector('.mm-payment-methods');
      if (paymentMethodsSection) {
        paymentMethodsSection.innerHTML = `
          <div class="mm-error-container">
            <p>❌ Failed to initiate mobile money payment: ${error.message}</p>
            <button class="btn btn-secondary" onclick="loadMobileMoneyPaymentPage('${paymentId}')">
              ← Back to Payment Methods
            </button>
          </div>
        `;
      }
    }
  }

  // Redirect to Lenco authorization URL
  function redirectToLenco(authorizationUrl, transactionId) {
    console.log('🔀 Redirecting to Lenco:', authorizationUrl);
    // Store transaction ID in sessionStorage for verification after return
    sessionStorage.setItem('lencoTransactionId', transactionId);
    window.location.href = authorizationUrl;
  }

  // Show Card Payment Form
  function showCardPaymentForm(paymentId) {
    closeModal();
    
    const payment = document.querySelector('[data-payment-id="' + paymentId + '"]');
    const amount = parseFloat(payment?.dataset.amount || 0);

    const cardModal = `
      <div class="modal-overlay" onclick="closeModal(event)">
        <div class="modal-content" onclick="event.stopPropagation()">
          <button class="modal-close" onclick="closeModal()">&times;</button>
          <h2>💳 Card Payment</h2>
          <form id="cardPaymentForm" onsubmit="processCardPayment(event, '${paymentId}')">
            <div class="form-group">
              <label for="cardNumber">Card Number</label>
              <input type="text" id="cardNumber" placeholder="1234 5678 9012 3456" maxlength="19" required />
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="expiryDate">Expiry Date</label>
                <input type="text" id="expiryDate" placeholder="MM/YY" maxlength="5" required />
              </div>
              <div class="form-group">
                <label for="cvv">CVV</label>
                <input type="text" id="cvv" placeholder="123" maxlength="4" required />
              </div>
            </div>
            <button type="submit" class="btn btn-primary btn-full">Pay ZMW ${amount.toFixed(2)}</button>
          </form>
        </div>
      </div>
    `;

    document.body.insertAdjacentHTML('beforeend', cardModal);
  }

  // Show Bank Transfer Information
  function showBankTransferInfo(paymentId) {
    closeModal();

    const bankModal = `
      <div class="modal-overlay" onclick="closeModal(event)">
        <div class="modal-content" onclick="event.stopPropagation()">
          <button class="modal-close" onclick="closeModal()">&times;</button>
          <h2>🏦 Bank Transfer Details</h2>
          <div class="bank-info">
            <p>Please transfer the payment amount to the following account:</p>
            <div class="bank-details">
              <p><strong>Bank Name:</strong> Standard Chartered Bank Zambia</p>
              <p><strong>Account Name:</strong> SafeTech Insurance Ltd</p>
              <p><strong>Account Number:</strong> 1234567890</p>
              <p><strong>Swift Code:</strong> SCBLZAZA</p>
              <p><strong>Reference:</strong> USE-YOUR-PAYMENT-ID</p>
            </div>
            <p class="note">⏳ Your payment will be marked as completed within 24 hours of receipt</p>
            <button class="btn btn-secondary" onclick="closeModal()">Close</button>
          </div>
        </div>
      </div>
    `;

    document.body.insertAdjacentHTML('beforeend', bankModal);
  }

  // Process Card Payment (placeholder)
  async function processCardPayment(event, paymentId) {
    event.preventDefault();
    alert('Card payment processing coming soon. Use mobile money for now.');
  }

  // View Receipt
  async function viewReceipt(paymentId) {
    try {
      const payment = await apiCall(`/api/payment/${paymentId}`);
      
      const receiptModal = `
        <div class="modal-overlay" onclick="closeModal(event)">
          <div class="modal-content" onclick="event.stopPropagation()">
            <button class="modal-close" onclick="closeModal()">&times;</button>
            <h2>Payment Receipt</h2>
            <div class="receipt">
              <div class="receipt-header">
                <h3>SafeTech Insurance</h3>
                <p>Payment Receipt</p>
              </div>
              <div class="receipt-body">
                <div class="receipt-row">
                  <span>Receipt ID:</span>
                  <span>${payment._id}</span>
                </div>
                <div class="receipt-row">
                  <span>Amount:</span>
                  <span>$${payment.amount.toFixed(2)}</span>
                </div>
                <div class="receipt-row">
                  <span>Plan:</span>
                  <span>${payment.plan?.planType?.toUpperCase()}</span>
                </div>
                <div class="receipt-row">
                  <span>Date:</span>
                  <span>${new Date(payment.createdAt).toLocaleDateString()}</span>
                </div>
                <div class="receipt-row">
                  <span>Status:</span>
                  <span>${payment.status}</span>
                </div>
              </div>
              <button class="btn btn-secondary" onclick="printReceipt()">Print Receipt</button>
            </div>
          </div>
        </div>
      `;

      document.body.insertAdjacentHTML('beforeend', receiptModal);
    } catch (error) {
      alert('Error viewing receipt: ' + error.message);
    }
  }

  function closeModal(event) {
    if (event && event.target !== event.currentTarget) return;
    const modal = document.querySelector('.modal-overlay');
    if (modal) modal.remove();
  }

  function printReceipt() {
    window.print();
  }

  // Verify Lenco Payment After Return
  async function verifyLencoPaymentReturn() {
    try {
      const transactionId = sessionStorage.getItem('lencoTransactionId');
      if (!transactionId) return;

      console.log('🔍 Verifying Lenco payment return:', transactionId);

      // Give user a moment to return from payment gateway
      await new Promise(resolve => setTimeout(resolve, 1500));

      const response = await apiCall('/api/payment/lenco/verify', {
        method: 'POST',
        body: JSON.stringify({ lencoTransactionId: transactionId })
      });

      // Clear from sessionStorage
      sessionStorage.removeItem('lencoTransactionId');

      if (response.message === 'Payment verified successfully') {
        console.log('✅ Lenco payment verified successfully');
        
        // Show success notification
        const notification = `
          <div class="notification notification-success">
            <div class="notification-content">
              <div class="notification-icon">✓</div>
              <h3>Payment Successful!</h3>
              <p>Your payment has been processed successfully. Thank you!</p>
            </div>
            <button onclick="this.parentElement.remove()" class="notification-close">&times;</button>
          </div>
        `;
        document.body.insertAdjacentHTML('beforeend', notification);

        // Reload payments after 2 seconds
        setTimeout(() => {
          loadPayments();
        }, 2000);
      } else if (response.status === 'pending') {
        console.log('⏳ Payment still pending');
        
        const notification = `
          <div class="notification notification-warning">
            <div class="notification-content">
              <div class="notification-icon">⏳</div>
              <h3>Payment Pending</h3>
              <p>Your payment is being processed. Please wait or check back later.</p>
            </div>
            <button onclick="this.parentElement.remove()" class="notification-close">&times;</button>
          </div>
        `;
        document.body.insertAdjacentHTML('beforeend', notification);

        setTimeout(() => {
          loadPayments();
        }, 2000);
      } else {
        console.warn('⚠️ Payment verification result:', response);
      }
    } catch (error) {
      console.error('Error verifying Lenco payment:', error.message);
    }
  }

  // Load on page load
  window.addEventListener('load', () => {
    loadPayments();
    
    // Check for Lenco payment return
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get('status') === 'success' || sessionStorage.getItem('lencoTransactionId')) {
      verifyLencoPaymentReturn();
    }
  });
</script>
    </div>
  </div>
</div>

