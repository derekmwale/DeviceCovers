  <div class="footer-container">
    <div class="footer-section">
      <h4>Dashboard</h4>
      <ul>
        <li><a href="/my-laptops">My Devices</a></li>
        <li><a href="/payments">Payments</a></li>
        <li><a href="/claims">Claims</a></li>
        <li><a href="/plans">Plans</a></li>
      </ul>
    </div>
    <div class="footer-section">
      <h4>Support</h4>
      <ul>
        <li><a href="#">Help Center</a></li>
