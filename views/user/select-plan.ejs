<script>
  const state = {
    selectedLaptopId: null,
    selectedLaptop: null,
    selectedPlanType: null,
    suggestedPlans: []
  };

  async function apiCall(url, options = {}) {
    const headers = {
      'Content-Type': 'application/json',
      ...options.headers,
    };

    console.log('🔌 API Call:', {
      url,
      method: options.method || 'GET',
      headers,
      bodyLength: options.body ? options.body.length : 0,
      bodyPreview: options.body ? options.body.substring(0, 100) : 'none'
    });

    const response = await fetch(url, {
      ...options,
      headers,
      credentials: 'include',
    });

    console.log('📨 API Response:', {
      url,
      status: response.status,
      ok: response.ok,
      contentType: response.headers.get('content-type')
    });

    if (!response.ok) {
      if (response.status === 401) {
        window.location.href = '/login';
      }
      const error = await response.json();
      console.error('❌ API Error:', error);
      throw new Error(error.message || 'API Error');
    }

    return response.json();
  }

  async function loadLaptops() {
    try {
      const laptops = await apiCall('/api/laptop');
      
      if (laptops.length === 0) {
        document.getElementById('laptopsGrid').innerHTML = `
          <div class="empty-state" style="grid-column: 1 / -1;">
            <p>📭 No laptops found. Please add a laptop first.</p>
            <a href="/add-laptop" class="btn btn-primary">+ Add Your First Laptop</a>
          </div>
        `;
        return;
      }

      const html = laptops.map(laptop => `
        <div class="laptop-card-selectable" onclick="selectLaptop('${laptop._id}', '${laptop.brand} ${laptop.model}', ${laptop.purchaseValue})">
          <h3>💻 ${laptop.brand} ${laptop.model}</h3>
          <p><strong>Serial:</strong> ${laptop.serialNumber}</p>
          <p><strong>Value:</strong> ZMW ${laptop.purchaseValue.toFixed(2)}</p>
          <p><strong>Condition:</strong> <span class="badge badge-${laptop.condition}">${laptop.condition}</span></p>
          <div class="select-indicator">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </div>
        </div>
      `).join('');

      document.getElementById('laptopsGrid').innerHTML = html;
    } catch (error) {
      document.getElementById('laptopsGrid').innerHTML = `<div class="error-message">Error loading laptops: ${error.message}</div>`;
    }
  }

  async function selectLaptop(laptopId, deviceName, deviceValue) {
    state.selectedLaptopId = laptopId;
    state.selectedLaptop = { name: deviceName, value: deviceValue };

    document.querySelectorAll('.laptop-card-selectable').forEach(card => {
      card.classList.remove('selected');
    });
    event.currentTarget.classList.add('selected');

    try {
      state.suggestedPlans = await apiCall(`/api/laptop/${laptopId}/suggested-plans`);
      displayPlans();
      goToStep(2);
    } catch (error) {
      alert('Error loading plans: ' + error.message);
    }
  }

  function displayPlans() {
    document.getElementById('selectedDeviceName').textContent = state.selectedLaptop.name;
    document.getElementById('selectedDeviceValue').textContent = 'ZMW ' + state.selectedLaptop.value.toFixed(2);

    const plansHtml = state.suggestedPlans.map(plan => `
      <div class="plan-card-comparison" onclick="selectPlan('${plan.type}', this)">
        <div class="plan-icon">
          ${plan.type === 'basic' ? '🛡️' : plan.type === 'premium' ? '⭐' : '👑'}
        </div>
        <h3>${plan.name}</h3>
        <p class="plan-price">ZMW ${plan.monthly.toFixed(2)}<span>/month</span></p>
        <div class="plan-features">
          <div class="feature">
            <strong>Coverage</strong>
            <p>ZMW ${plan.coverage.toFixed(2)}</p>
          </div>
          <div class="feature">
            <strong>Deductible</strong>
            <p>ZMW ${(plan.coverage * 0.1).toFixed(2)}</p>
          </div>
        </div>
        <p class="plan-description">${plan.description}</p>
        <div class="plan-highlights">
          <span class="highlight">✓ ${plan.type === 'basic' ? 'Water Damage' : plan.type === 'premium' ? 'Theft & Damage' : 'Complete Coverage'}</span>
          <span class="highlight">✓ 24/7 Support</span>
        </div>
      </div>
    `).join('');

    document.getElementById('plansComparison').innerHTML = plansHtml;
  }

  function selectPlan(planType, element) {
    state.selectedPlanType = planType;

    document.querySelectorAll('.plan-card-comparison').forEach(card => {
      card.classList.remove('selected');
    });
    element.classList.add('selected');
    document.getElementById('continueBtn').disabled = false;
  }

  function continueToPlan() {
    if (!state.selectedPlanType) {
      alert('Please select a plan');
      return;
    }

    const plan = state.suggestedPlans.find(p => p.type === state.selectedPlanType);
    
    document.getElementById('reviewDevice').textContent = state.selectedLaptop.name;
    document.getElementById('reviewValue').textContent = 'ZMW ' + state.selectedLaptop.value.toFixed(2);
    document.getElementById('reviewPlanType').textContent = plan.name;
    document.getElementById('reviewPremium').textContent = 'ZMW ' + plan.monthly.toFixed(2) + '/month';
    document.getElementById('reviewCoverage').textContent = 'ZMW ' + plan.coverage.toFixed(2);
    document.getElementById('reviewDeductible').textContent = 'ZMW ' + (plan.coverage * 0.1).toFixed(2);

    const coverageItems = {
      basic: ['Water damage protection', 'Up to ZMW 5,000 coverage', 'Email support', 'Standard processing'],
      premium: ['Theft & damage protection', 'Up to ZMW 15,000 coverage', '24/7 phone support', 'Water & liquid damage', 'Fast processing'],
      pro: ['Complete coverage', '90% device value protection', 'Loss protection included', 'Extended warranty', 'Priority support']
    };

    const items = coverageItems[state.selectedPlanType] || [];
    document.getElementById('coverageList').innerHTML = items
      .map(item => `<li><strong>✓</strong> ${item}</li>`)
      .join('');

    goToStep(3);
  }

  async function confirmPlan() {
    try {
      // Double-check state validity (defensive programming)
      const laptopId = state.selectedLaptopId;
      const planType = state.selectedPlanType;

      console.log('🔐 Final Validation Check:',  {
        laptopId: laptopId,
        planType: planType,
        laptopIdValid: !!laptopId && laptopId.length > 0,
        planTypeValid: !!planType && ['basic', 'premium', 'pro'].includes(planType)
      });

      // Validate laptop ID
      if (!laptopId || typeof laptopId !== 'string' || laptopId.trim() === '') {
        alert('⚠️ No laptop selected. Please go back and select a laptop.');
        goToStep(1);
        return;
      }

      // Validate plan type
      if (!planType || !['basic', 'premium', 'pro'].includes(planType)) {
        alert('⚠️ Invalid plan type selected. Please go back and select a valid plan.');
        goToStep(2);
        return;
      }

      const submitBtn = document.getElementById('confirmBtn');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Processing...';

      // Build and submit payload
      const payload = {
        laptopId: laptopId.trim(),
        planType: planType.toLowerCase()
      };
      
      console.log('📤 Final Payload:', payload);

      const response = await apiCall('/api/plan', {
        method: 'POST',
        body: JSON.stringify(payload)
      });

      console.log('✅ Plan created successfully:', response);
      alert('✓ Plan activated successfully! Your device is now covered.');
      window.location.href = '/plans';
    } catch (error) {
      console.error('❌ Plan creation error:', error);
      let errorMsg = error.message;
      
      // Provide specific feedback
      if (errorMsg.includes('Missing')) {
        errorMsg = 'Required fields are missing. Please complete all steps.';
      } else if (errorMsg.includes('Laptop not found')) {
        errorMsg = 'The selected laptop was not found. Please select again.';
      }
      
      alert('Error: ' + errorMsg);
      
      const submitBtn = document.getElementById('confirmBtn');
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = '✓ Confirm & Activate Plan';
      }
    }
  }

  function goToStep(stepNum) {
    // Validate that we can go to this step
    if (stepNum === 2 && !state.selectedLaptopId) {
      alert('⚠️ Please select a laptop first');
      return;
    }
    
    if (stepNum === 3 && (!state.selectedLaptopId || !state.selectedPlanType)) {
      alert('⚠️ Please complete all previous steps');
      return;
    }

    document.querySelectorAll('.wizard-step').forEach(step => {
      step.classList.remove('active');
    });
    document.getElementById(`step${stepNum}`).classList.add('active');
    window.scrollTo(0, 0);
  }

  function goBack() {
    if (document.getElementById('step3').classList.contains('active')) {
      goToStep(2);
    } else if (document.getElementById('step2').classList.contains('active')) {
      goToStep(1);
    }
  }

  // Initialize
  window.addEventListener('load', () => {
    loadLaptops();
  });
</script>
<script src="/js/main.js"></script>
</body>
</html>
